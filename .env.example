# ── Database ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=forex_accounting
DB_USER=postgres
DB_PASSWORD=your_password
DB_POOL_MAX=20

# ── Redis (BullMQ on DB 0, Cache on DB 1) ────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Auth (JWT) ───────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_32chars
JWT_REFRESH_SECRET=change_me_refresh_secret_32chars

# ── AWS S3 (PDF/Excel report storage) ────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=forex-accounting-reports

# ── MT5 Integration ───────────────────────────────
MT5_BRIDGE_HOST=localhost
MT5_BRIDGE_PORT=9090
MT5_BRIDGE_SECRET=your_bridge_secret

# ── App ───────────────────────────────────────────
NODE_ENV=development
PORT=3000
